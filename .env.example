# =============================================================================
# BEO Automation - Environment Variables Template
# =============================================================================
# 
# ⚠️  SECURITY WARNING: This is an EXAMPLE file with FAKE placeholder values!
#     DO NOT commit real credentials to version control.
#
# Instructions:
# 1. Copy this file to .env.local (already in .gitignore)
# 2. Replace ALL placeholder values with your real credentials
# 3. Never commit .env.local or any file containing real secrets
# =============================================================================

# -----------------------------------------------------------------------------
# Airtable Configuration
# -----------------------------------------------------------------------------
# Get your Personal Access Token from: https://airtable.com/create/tokens
# The base ID can be found in your Airtable URL
AIRTABLE_TOKEN=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# -----------------------------------------------------------------------------
# Doppler Configuration (Secrets Management)
# -----------------------------------------------------------------------------
# Sign up at: https://doppler.com
# Create a project and get your service token
DOPPLER_TOKEN=your_doppler_service_token_here
DOPPLER_PROJECT=beo-automation
DOPPLER_CONFIG=dev

# -----------------------------------------------------------------------------
# Warp API Configuration
# -----------------------------------------------------------------------------
# ⚠️  PLACEHOLDER VALUES - Replace with your real Warp API credentials
# Contact your Warp API provider for authentication tokens
# 
# Note: NEXT_PUBLIC_* variables are exposed to the browser!
# Only use NEXT_PUBLIC_ prefix if the credential MUST be client-accessible.
WARP_API_KEY=your_warp_api_key_here
NEXT_PUBLIC_WARP_API_KEY=your_warp_api_key_here

# -----------------------------------------------------------------------------
# OZ Environment Configuration
# -----------------------------------------------------------------------------
# ⚠️  PLACEHOLDER VALUES - Replace with your real OZ environment ID
# This should be a unique identifier for your OZ environment
# 
# Note: NEXT_PUBLIC_* variables are exposed to the browser!
OZ_ENVIRONMENT_ID=your_oz_environment_id_here
NEXT_PUBLIC_OZ_ENVIRONMENT_ID=your_oz_environment_id_here

# -----------------------------------------------------------------------------
# Application Environment
# -----------------------------------------------------------------------------
# Valid values: development, staging, production
ENVIRONMENT_ID=development
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# Next.js Configuration
# -----------------------------------------------------------------------------
# Update this URL based on your deployment environment:
# - Local: http://localhost:3000
# - Staging: https://staging.yourdomain.com
# - Production: https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
#
# For Production Deployment:
# 1. Set all environment variables in your hosting platform (Vercel, Netlify, etc.)
# 2. Use Doppler for centralized secrets management
# 3. Never use .env files in production - use platform environment variables
# 4. Rotate credentials regularly and after any suspected exposure
#
# For Vercel Deployment:
# - Go to Project Settings → Environment Variables
# - Add each variable above with your real values
# - Separate configs for Production, Preview, and Development
#
# For Local Development:
# - Copy this file to .env.local
# - Replace all placeholder values with real credentials
# - The .env.local file is gitignored and safe for local use
# =============================================================================

# -----------------------------------------------------------------------------
# n8n + Composio runtime configuration
# -----------------------------------------------------------------------------
# n8n should call the internal API through this base URL.
INTERNAL_API_BASE_URL=http://localhost:3000

# Optional for repo-driven sync into n8n Cloud (`npm run workflow:sync:n8n`).
N8N_API_BASE_URL=
N8N_API_KEY=

# Composio multi-execute endpoint + API key used by n8n HTTP nodes.
COMPOSIO_MULTI_EXECUTE_URL=
COMPOSIO_API_KEY=

# Notion database used for ready-to-generate polling.
NOTION_EVENT_DB_ID=
NOTION_STATUS_PROPERTY=Workflow Status
NOTION_READY_STATUS=Ready to Generate
NOTION_READY_PAGE_SIZE=100

# Optional fixed Composio session ID for outbound email calls.
COMPOSIO_EMAIL_SESSION_ID=

# -----------------------------------------------------------------------------
# Carbone template mapping (used through Composio tools)
# -----------------------------------------------------------------------------
# Set at least ONE template ID:
# - CARBONE_TEMPLATE_DEFAULT_ID for all audiences, or
# - audience-specific template IDs below.
CARBONE_TEMPLATE_DEFAULT_ID=
CARBONE_TEMPLATE_KITCHEN_ID=
CARBONE_TEMPLATE_SERVICE_ID=
CARBONE_TEMPLATE_CLIENT_ID=

# Optional fallback only for renderId->download URL construction.
CARBONE_API_BASE_URL=https://api.carbone.io

# -----------------------------------------------------------------------------
# Internal workflow auth + reliability controls
# -----------------------------------------------------------------------------
# Shared bearer token required on all /api/workflows/* calls.
WORKFLOW_INTERNAL_TOKEN=replace_with_strong_internal_token

# Trusted caller role derived from authenticated workflow caller.
# Valid: chef, lead, service-manager, ops-manager, admin, system
WORKFLOW_CALLER_ROLE=system

# Optional webhook target for real terminal-status writes.
# If unset, the terminal-status route uses a mock writer.
TERMINAL_STATUS_WEBHOOK_URL=

# Set true only for fallback-path testing.
SIMULATE_TERMINAL_STATUS_FAILURE=false

# Optional JSON object to override role policy for sensitive actions.
# Example:
# {"ready_to_generate":["lead","admin"],"dead_letter_replay":["ops-manager","admin"]}
# Generate presets with: npm run role-policy:seed -- --env <development|staging|production>
WORKFLOW_ROLE_POLICY_OVERRIDES=

# -----------------------------------------------------------------------------
# Dead-letter storage backend
# -----------------------------------------------------------------------------
# Valid values: file | supabase
DEAD_LETTER_BACKEND=file

# File backend path (used when DEAD_LETTER_BACKEND=file).
DEAD_LETTER_DIR=./data/dead-letter

# Supabase backend settings (required when DEAD_LETTER_BACKEND=supabase).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Supabase pruning thresholds (database-size based).
DEAD_LETTER_MAX_DB_MB=470
DEAD_LETTER_TARGET_DB_MB=430
DEAD_LETTER_MAX_DELETE_BATCH=2000
